{
  "name": "in-need-of-time",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "studio",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "prepare": "if [ -z \"$CI\" ] && [ \"$VERCEL\" != \"1\" ]; then simple-git-hooks; fi",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "frontend": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/frontend dev",
    "frontend:build": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/frontend build",
    "studio": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/studio dev",
    "studio:typegen": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/studio typegen",
    "studio:type-check": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/studio type-check",
    "studio:generate-types": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/studio generate-types",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down && docker volume rm $(docker volume ls -q --filter name=neon_data) && docker compose up -d",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down && docker volume rm $(docker volume ls -q --filter name=neon_data) && docker-compose up -d",
    "db:push": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/db db:push",
    "db:studio": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/db db:studio",
    "db:migrate": "dotenv -e ./.env.local -- npm run -w @in-need-of-time/db db:migrate"
  },
  "simple-git-hooks": {
    "pre-commit": "npx pretty-quick --staged"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.12",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
}
